cache/elibrary_cache.pkl
cache/elibrary_cache.json
cache/editorials_cache.pkl
cache/editorials_cache.json
cache/__pycache__/

# ─── Vector store — recreatable indexes ────────────────────────────
# query_history.json and query_history_embeddings.npy ARE included
vector_store/elibrary.faiss
vector_store/elibrary_meta.json
vector_store/elibrary_build.json
